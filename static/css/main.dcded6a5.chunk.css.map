.HomeContainer {
    font-family: 'Primitive';
    margin: 0 15vw;
    height: 100%;
}

.HomeTitle {
    font-size: 3rem;
    font-family: 'Primitive';

    margin: 33px 0px;
}

.HomeBody {
    font-family:'Trebuchet MS', 'Lucida Sans Unicode', 'Lucida Grande', 'Lucida Sans', Arial, sans-serif
}

.HomeBlogTitle {
    font-size: 1.25rem;
    margin-bottom: 15px;
}

/* -----RESPONSIVE DESIGN TEMPLATES----- */
/* -------DESKTOP-FIRST TEMPLATE------- */
/* Extra large devices (large laptops/desktops, 1201px and up) */
@media only screen and (min-width: 1201px) {

}  
/* Large devices (laptops/desktops, 1200px and down) */
@media only screen and (max-width: 1200px) {

} 

/* Medium devices (landscape tablets, 992px and down) */
@media only screen and (max-width: 992px) {
   
}

 /* Small devices (portrait tablets and large phones, 768px and down) */
@media only screen and (max-width: 768px) {
    
    .HomeTitle {
        font-size: 2rem;
    }
    .HomeBody {
        font-size: 0.9rem;
    }
    .HomeBlogTitle {
        font-size: 1.15rem;
        margin-bottom: 15px;
    }

}

/* Extra small devices - landscape (RatChecker landscape smartphone and portrait tablet look different) */
@media only screen and (max-width: 768px) and (orientation: landscape) {

}

 /* Extra small devices (phones, 600px and down) */
@media only screen and (max-width: 600px) {
    
    .HomeTitle {
        font-size: 1.75rem;
    }
    .HomeBody {
        font-size: 0.9rem;
    }
    .HomeBlogTitle {
        font-size: 1.15rem;
        margin-bottom: 15px;
    }
}